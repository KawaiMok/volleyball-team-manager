// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TeamRole {
  ADMIN
  COACH
  /** 教練兼球員：具教練端與球員端權限（註解：單一隊籍雙身份）。 */
  COACH_PLAYER
  STAFF
  PLAYER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

/** 組織內角色（註解：多租戶 SaaS；ORG_ADMIN 可建隊、指派教練）。 */
enum OrganizationRole {
  ORG_ADMIN
  ORG_STAFF
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

/** 球隊生命週期（註解：與 MemberStatus 分開；ARCHIVED 後教練端可限制新建事件）。 */
enum TeamLifecycleStatus {
  ACTIVE
  ARCHIVED
}

/** Logo／Avatar 風格（註解：預設＝通用排球；CIQING＝慈青體育會）。 */
enum BrandStyle {
  DEFAULT
  CIQING
}

enum EventType {
  TRAINING
  MATCH
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum RsvpStatus {
  UNANSWERED
  YES
  NO
  MAYBE
}

enum FatigueLevel {
  LOW
  MED
  HIGH
}

enum PainLevel {
  NONE
  MILD
  SEVERE
}

enum CommentType {
  ANNOUNCEMENT
  COMMENT
}

enum FileAssetKind {
  LINK
  UPLOAD
}

/** 事件連結用途（註解：戰術板／影片整理；GENERAL 供未來其他附件）。 */
enum FileAssetCategory {
  GENERAL
  TACTICAL_BOARD
  VIDEO
}

/** 原生推播通路（註解：Capacitor FCM／APNs；之後若加 Web Push 再擴充）。 */
enum PushPlatform {
  IOS
  ANDROID
}

/** 每隊 AI 每小時呼叫計數（註解：serverless 多 instance 共用限流窗口）。 */
model AiRateLimitWindow {
  teamId      String   @id
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String?  @unique
  email       String?  @unique
  name        String?
  avatarUrl   String?
  /** Logo／Avatar 風格偏好（註解：預設 DEFAULT；慈青 CIQING）。 */
  brandStyle  BrandStyle @default(DEFAULT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships           TeamMember[]
  pushDevices           PushDevice[]
  notifications         UserNotification[]
  organizationMembers   OrganizationMember[]
  platformAdmin         PlatformAdmin?
}

/** App 內通知紀錄（註解：與 FCM 推播同步寫入；供「通知」頁面瀏覽）。 */
model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  teamId    String?
  kind      String
  title     String
  body      String
  path      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

/** 使用者裝置推播 token（註解：以 token 全域唯一；換帳登入時由 API 改綁）。 */
model PushDevice {
  id        String       @id @default(cuid())
  userId    String
  token     String       @unique
  platform  PushPlatform
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/** 多租戶組織（註解：協會／學校等；旗下可有多支球隊）。 */
model Organization {
  id           String             @id @default(cuid())
  name         String
  slug         String             @unique
  status       OrganizationStatus @default(ACTIVE)
  contactEmail String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  members OrganizationMember[]
  teams   Team[]
}

/** 組織成員（註解：ORG_ADMIN 可管理組織內球隊；依 Email 預建，Clerk 登入後合併）。 */
model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole
  status         MemberStatus     @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, status])
}

/** 平台超管（註解：跨組織；與 PLATFORM_ADMIN_EMAILS 環境變數互補）。 */
model PlatformAdmin {
  userId    String   @id
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** 平台操作審計（註解：Phase 2 UI；先建表供 API 寫入）。 */
model PlatformAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([targetType, targetId])
}

model Team {
  id          String   @id @default(cuid())
  organizationId String
  name        String
  season      String?
  timezone    String   @default("Asia/Taipei")
  lifecycleStatus TeamLifecycleStatus @default(ACTIVE)
  groupConfig Json?
  /** Email 等通知偏好（註解：實際寄信／排程尚未接時仍可先存設定）。 */
  notificationSettings Json?
  /** 即時戰術版 JSON（註解：與 Event.courtSketch 同結構；供總覽進入之白板）。 */
  liveTacticalSketch Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  members      TeamMember[]
  events       Event[]
  trainingPlans TrainingPlan[]
  comments     Comment[]
  fileAssets   FileAsset[]

  @@index([organizationId])
}

model TeamMember {
  id                     String       @id @default(cuid())
  teamId                 String
  userId                 String
  role                   TeamRole
  status                 MemberStatus @default(ACTIVE)
  jerseyNumber           Int?
  position               String?
  squad                  String?
  phone                  String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  notes                  String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdEvents Event[] @relation("EventCreatedBy")
  publishedEvents Event[] @relation("EventPublishedBy")
  comments Comment[] @relation("CommentAuthor")
  fileAssets FileAsset[] @relation("FileAssetUploadedBy")

  participants EventParticipant[]
  attendanceAsMember Attendance[] @relation("AttendanceMember")
  attendanceCheckedIn  Attendance[] @relation("AttendanceCheckedInBy")
  feedback     Feedback[]
  /** 教練對該隊員的私評（註解：subject）。 */
  playerReviewsReceived EventPlayerReview[] @relation("PlayerReviewSubject")
  /** 教練撰寫的私評（註解：author）。 */
  playerReviewsAuthored EventPlayerReview[] @relation("PlayerReviewAuthor")
  /** 比賽個人數據（註解：MATCH 事件）。 */
  matchPlayerStats MatchPlayerStat[]
  /** 登錄的比賽結果（註解：recordedBy）。 */
  matchResultsRecorded MatchResult[] @relation("MatchResultRecordedBy")

  @@unique([teamId, userId])
  @@unique([teamId, jerseyNumber])
  @@index([userId, status])
}

model Event {
  id                 String      @id @default(cuid())
  teamId             String
  type               EventType
  title              String
  description        String?
  startsAt           DateTime
  endsAt             DateTime
  meetAt             DateTime?
  locationName       String?
  status             EventStatus @default(DRAFT)
  rsvpDeadlineAt     DateTime?
  createdByMemberId  String
  publishedAt        DateTime?
  publishedByMemberId String?
  /** 場上企位示意 JSON（註解：正規化座標 tokens；教練編輯、球員唯讀）。 */
  courtSketch         Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy TeamMember @relation("EventCreatedBy", fields: [createdByMemberId], references: [id], onDelete: Restrict)
  publishedBy TeamMember? @relation("EventPublishedBy", fields: [publishedByMemberId], references: [id], onDelete: SetNull)

  participants EventParticipant[]
  attendance   Attendance[]
  trainingPlan TrainingPlan?
  feedback     Feedback[]
  comments     Comment[]
  fileAssets   FileAsset[]
  /** 教練對參與球員的私評（註解：僅教練與該球員可見）。 */
  playerReviews EventPlayerReview[]
  /** 比賽結果（註解：僅 MATCH 類型；一事件一筆）。 */
  matchResult   MatchResult?

  @@index([teamId, startsAt])
  @@index([teamId, status, startsAt])
}

model EventParticipant {
  id        String   @id @default(cuid())
  eventId   String
  memberId  String
  createdAt DateTime @default(now())

  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
}

model Attendance {
  id               String     @id @default(cuid())
  eventId          String
  memberId         String
  rsvpStatus       RsvpStatus @default(UNANSWERED)
  rsvpReason       String?
  rsvpAt           DateTime?
  checkedIn        Boolean    @default(false)
  checkedInAt      DateTime?
  checkedInByMemberId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member TeamMember @relation("AttendanceMember", fields: [memberId], references: [id], onDelete: Cascade)
  checkedInBy TeamMember? @relation("AttendanceCheckedInBy", fields: [checkedInByMemberId], references: [id], onDelete: SetNull)

  @@unique([eventId, memberId])
  @@index([eventId, rsvpStatus])
}

model TrainingPlan {
  id               String   @id @default(cuid())
  teamId           String
  eventId          String   @unique
  title            String?
  summary          String?
  equipmentList    Json?
  safetyNotes      String?
  aiProvenance     Json?
  createdByMemberId String
  updatedByMemberId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  blocks TrainingBlock[]
}

model TrainingBlock {
  id           String   @id @default(cuid())
  planId       String
  order        Int
  name         String
  minutes      Int
  goal         String
  setup        String?
  steps        Json
  coachCues    Json?
  groupingPlan String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plan TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, order])
}

model Feedback {
  id          String       @id @default(cuid())
  eventId     String
  memberId    String
  rpe         Int
  fatigue     FatigueLevel
  painLevel   PainLevel
  painArea    String?
  note        String?
  submittedAt DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([memberId, submittedAt(sort: Desc)])
}

/** 教練對單一場次、單一球員的私評（註解：非公開留言；僅教練端與該球員可讀）。 */
model EventPlayerReview {
  id               String   @id @default(cuid())
  eventId          String
  memberId         String
  authorMemberId   String
  content          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member TeamMember @relation("PlayerReviewSubject", fields: [memberId], references: [id], onDelete: Cascade)
  author TeamMember @relation("PlayerReviewAuthor", fields: [authorMemberId], references: [id], onDelete: Restrict)

  @@unique([eventId, memberId])
}

/** 比賽結果（註解：事件須為 MATCH；含比分、球隊與個人數據）。 */
model MatchResult {
  id                 String   @id @default(cuid())
  eventId            String   @unique
  opponentName       String?
  /** 各局比分 JSON：[{ our, opponent }] */
  sets               Json
  /** 球隊整體數據 JSON（註解：得分、失誤、Ace 等）。 */
  teamStats          Json?
  notes              String?
  recordedByMemberId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recordedBy TeamMember         @relation("MatchResultRecordedBy", fields: [recordedByMemberId], references: [id], onDelete: Restrict)
  playerStats MatchPlayerStat[]
}

/** 比賽個人數據（註解：攻擊、攔網、防守、一傳、發球、其他；JSON 結構見 match-result-schema）。 */
model MatchPlayerStat {
  id            String   @id @default(cuid())
  matchResultId String
  memberId      String
  /** 六大類細項計數 JSON（註解：rating/百分比由前端即時計算）。 */
  stats         Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Cascade)
  member      TeamMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([matchResultId, memberId])
  @@index([memberId])
}

model Comment {
  id             String      @id @default(cuid())
  teamId         String
  eventId        String
  authorMemberId String
  type           CommentType @default(COMMENT)
  content        String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  team   Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author TeamMember @relation("CommentAuthor", fields: [authorMemberId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

model FileAsset {
  id                String        @id @default(cuid())
  teamId            String
  eventId           String?
  uploadedByMemberId String
  kind              FileAssetKind @default(LINK)
  category          FileAssetCategory @default(GENERAL)
  url               String
  name              String?
  mimeType          String?
  sizeBytes         Int?
  createdAt         DateTime      @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy TeamMember @relation("FileAssetUploadedBy", fields: [uploadedByMemberId], references: [id], onDelete: Cascade)

  @@index([eventId])
}
